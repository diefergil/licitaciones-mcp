# Production template. Copy to .env and replace secrets on the server.
LICITACIONES_ENV=production
LICITACIONES_LOG_LEVEL=INFO

POSTGRES_PASSWORD=replace-with-generated-password
DATABASE_URL=postgresql+asyncpg://licitaciones:replace-with-generated-password@postgres:5432/licitaciones

LICITACIONES_PUBLIC_HOST=mcp.example.com
LICITACIONES_MCP_HOST=0.0.0.0
LICITACIONES_MCP_PORT=8080
LICITACIONES_MCP_TRANSPORT=streamable-http
LICITACIONES_MCP_AUTH_TOKEN=replace-with-generated-token

LICITACIONES_CACHE_DIR=/var/cache/licitaciones-mcp
LICITACIONES_PLACSP_RATE_PER_SEC=2
LICITACIONES_TED_RATE_PER_SEC=1
LICITACIONES_HTTP_MAX_ATTEMPTS=5

PLACSP_FEED_URL=https://contrataciondelsectorpublico.gob.es/sindicacion/sindicacion_643/licitacionesPerfilesContratanteCompleto3.atom
PLACSP_VERIFY_SSL=true
TED_API_BASE_URL=https://api.ted.europa.eu/v3

LICITACIONES_EMBEDDINGS_PROVIDER=openai
LICITACIONES_EMBEDDINGS_MODEL=text-embedding-3-small
OPENAI_API_KEY=replace-with-embeddings-only-key
