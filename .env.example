# Runtime
LICITACIONES_ENV=local
LICITACIONES_LOG_LEVEL=INFO

# Required for real deployments
POSTGRES_PASSWORD=change-me-before-deploy
DATABASE_URL=postgresql+asyncpg://licitaciones:change-me-before-deploy@localhost:55432/licitaciones

# MCP server
LICITACIONES_MCP_HOST=127.0.0.1
LICITACIONES_MCP_PORT=8080
LICITACIONES_MCP_TRANSPORT=streamable-http

# Optional embeddings
# Embeddings are disabled unless these values are provided.
LICITACIONES_EMBEDDINGS_PROVIDER=
LICITACIONES_EMBEDDINGS_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# Sources
PLACSP_FEED_URL=
PLACSP_VERIFY_SSL=true
TED_API_BASE_URL=https://api.ted.europa.eu/v3
